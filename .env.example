# xueqiu-monitor 生产环境配置
# 复制此文件为 .env 并填入真实值（.env 已加入 .gitignore）

# 字节 coding plan / ARK OpenAI-compatible API（情感分析 LLM）
# 优先使用 ARK_API_KEY；本地 Hermes/code-plan 环境也兼容 ARKCODE_API_KEY。
ARK_API_KEY=your-ark-api-key
# ARKCODE_API_KEY=your-arkcode-api-key
ARK_CODING_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3

# 飞书推送（二选一或同时配置）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx
LARK_CHAT_ID=oc_xxxxxxxxxxxxx

# 外部路径（覆盖 etc/config.json 中的默认值）
# XUEQIU_ANALYZER_PATH=/root/code/xueqiu-analyzer-skill/src
# MORNING_BRIEF_DB=/root/code/morning-brief/data/morning-brief.db
