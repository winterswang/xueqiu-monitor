# xueqiu-monitor 生产环境配置
# 复制此文件为 .env 并填入真实值（.env 已加入 .gitignore）

# MiniMax / 代理 API（情感分析 LLM）
MINIMAX_API_KEY=sk-cp-xxxxx
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic

# 飞书推送
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx

# 外部路径（覆盖 etc/config.json 中的默认值）
# XUEQIU_ANALYZER_PATH=/root/code/xueqiu-analyzer-skill/src
# MORNING_BRIEF_DB=/root/code/morning-brief/data/morning-brief.db
